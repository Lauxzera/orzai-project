{
  "name": "orzai-project",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "dev": "next dev --webpack -H 127.0.0.1",
    "dev:net": "next dev --webpack -H 0.0.0.0",
    "build": "node ./node_modules/prisma/build/index.js generate && next build --webpack",
    "start": "next start",
    "lint": "node ./node_modules/typescript/bin/tsc -p tsconfig.typecheck.json --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "lint:encoding": "node scripts/check-encoding.js",
    "ops:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/backup-orzai-project.ps1",
    "ops:restore": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/restore-orzai-project.ps1",
    "ops:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-orzai-project.ps1",
    "ops:whatsapp-readiness": "node ./scripts/check-whatsapp-coexistence-readiness.js",
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:apply:coexistence": "node ./scripts/apply-coexistence-schema.js",
    "db:apply:predictive-score": "node ./scripts/apply-predictive-score-schema.js",
    "db:apply:funnel-simplification": "node ./scripts/apply-funnel-status-simplification.js",
    "db:apply:appointment": "node ./scripts/apply-appointment-schema.js",
    "db:apply:followup": "node ./scripts/apply-followup-schema.js",
    "db:studio": "node ./node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tabs": "latest",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "latest",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.0",
    "googleapis": "^171.4.0",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "latest",
    "next": "latest",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "radix-ui": "^1.6.0",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prisma": "^7.8.0",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  }
}
