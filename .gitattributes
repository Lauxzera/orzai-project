# Store all text files with LF in the repository.
# eol=lf ensures Git never runs CRLF conversion that can corrupt
# multi-byte UTF-8 sequences (Portuguese accents like á, ã, ç, etc.)
* text=auto eol=lf

# Source files — explicitly UTF-8, LF only
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf

# Binary files — never modify
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.wasm  binary
