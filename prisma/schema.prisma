generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
  VIEWER
}

enum FunnelStatus {
  NOVO_LEAD
  EM_CONVERSA
  AGUARDANDO_RETORNO
  NEGOCIACAO
  MATRICULADO
}

enum EnrollmentStatus {
  NAO_INICIADO
  INTERESSADO
  AGUARDANDO_PAGAMENTO
  PAGAMENTO_CONFIRMADO
  MATRICULADO
  CANCELADO
  REMANEJADO
}

enum ChatMessageDirection {
  inbound
  outbound
}

enum ChatMessageType {
  text
  image
  audio
  document
}

enum ChatMessageStatus {
  sent
  delivered
  read
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum FollowUpStatus {
  PENDING
  CANCELLED
}

model User {
  id              String               @id @default(cuid())
  name            String
  username        String               @unique
  passwordHash    String
  role            UserRole             @default(SALES)
  active          Boolean              @default(true)
  isAgent         Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  leads           Lead[]               @relation("LeadOwner")
  history         LeadHistory[]
  departmentRoles UserDepartmentRole[]
}

model Lead {
  id                 String           @id @default(cuid())
  nome               String
  telefone           String
  whatsapp           String?
  email              String?
  cursoDeInteresse   String
  origem             String
  origemDetalhe      String?
  captadoVia         String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmTerm            String?
  utmContent         String?
  trackingReferrer   String?
  trackingLandingPage String?
  trackingId         String?
  statusFunil        FunnelStatus     @default(NOVO_LEAD)
  statusMatricula    EnrollmentStatus @default(NAO_INICIADO)
  responsavelId      String?
  responsavelNome    String
  dataEntrada        DateTime
  proximoContato     DateTime?
  objecaoPrincipal   String?
  observacoes        String?
  jaFoiAluno         Boolean          @default(false)
  cidade             String?
  profissao          String?
  predictiveScore    Int?
  predictiveScoreConfidence String?
  predictiveScoreReasons String[]      @default([])
  predictiveScoreRisks String[]        @default([])
  predictiveScoreSource String?
  predictiveScoreUpdatedAt DateTime?
  departmentId       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  archivedAt         DateTime?
  responsavel        User?            @relation("LeadOwner", fields: [responsavelId], references: [id])
  department         Department?      @relation(fields: [departmentId], references: [id])
  tasks              Task[]
  history            LeadHistory[]
  appointments       Appointment[]
  scheduledFollowUps ScheduledFollowUp[]

  @@index([statusFunil])
  @@index([statusMatricula])
  @@index([origem])
  @@index([utmSource])
  @@index([utmCampaign])
  @@index([cursoDeInteresse])
  @@index([responsavelNome])
  @@index([proximoContato])
  @@index([telefone])
  @@index([email])
  @@index([archivedAt])
  @@index([updatedAt])
  @@index([predictiveScoreUpdatedAt])
  @@index([departmentId])
}

model Task {
  id          String    @id @default(cuid())
  leadId      String
  title       String
  owner       String
  dueDate     DateTime
  done        Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([owner])
  @@index([dueDate])
  @@index([done])
  @@index([archivedAt])
}

model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  action    String
  note      String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}

model LeadListRecord {
  id          String   @id
  name        String
  description String   @default("")
  color       String
  leadIds     String[]
  createdAt   DateTime
  updatedAt   DateTime

  @@index([updatedAt])
}

model CrmCustomizationState {
  id                        String   @id
  courses                   String[]
  courseSegmentsFormacao    String[]
  courseSegmentsEspecializacao String[]
  origins                   String[]
  leadCaptureMethods        String[]
  owners                    String[]
  updatedAt                 DateTime @updatedAt
}

model AdminAuditRecord {
  id             String   @id
  actorId        String?
  actorName      String
  action         String
  targetUserId   String
  targetUserName String
  details        String
  changeTypes    Json?
  createdAt      DateTime

  @@index([createdAt])
  @@index([targetUserId])
}

model MessageConversation {
  id                   String               @id
  contactPhone         String
  contactName          String
  lastMessage          String               @default("")
  lastMessageAt        DateTime
  lastMessageDirection ChatMessageDirection?
  unreadCount          Int                  @default(0)
  source               String?
  departmentId         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  department           Department?          @relation(fields: [departmentId], references: [id])
  messages             MessageRecord[]
  insight              ConversationInsight?

  @@index([lastMessageAt])
  @@index([contactPhone])
  @@index([departmentId])
}

model MessageRecord {
  id                String               @id
  conversationId    String
  direction         ChatMessageDirection
  type              ChatMessageType
  content           String               @default("")
  mediaUrl          String?
  status            ChatMessageStatus
  statusError       String?
  timestamp         DateTime
  externalMessageId String?              @unique
  externalMediaId   String?
  mimeType          String?
  fileName          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  conversation      MessageConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@index([timestamp])
}

model MessageWorkspaceRecord {
  conversationKey String   @id
  priority        String
  serviceStatus   String
  tags            String[]
  pinnedNote      String   @default("")
  attempts        Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessageCampaignRecord {
  id              String   @id
  title           String
  messageTemplate String
  delaySeconds    Int
  status          String
  createdAt       DateTime
  updatedAt       DateTime
  createdByName   String
  startedAt       DateTime?
  completedAt     DateTime?
  nextDispatchAt  DateTime?
  recipients      Json

  @@index([createdAt])
  @@index([status])
}

model RoundRobinState {
  id           String      @id @default("global")
  nextIndex    Int         @default(0)
  departmentId String?
  updatedAt    DateTime    @updatedAt
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model MessageChannelConfigRecord {
  id                    String      @id
  provider              String
  mode                  String
  embeddedSignupEnabled Boolean     @default(false)
  coexistenceEnabled    Boolean     @default(false)
  metaAppId             String?
  metaAppConfigId       String?
  redirectUri           String?
  onboardingStatus      String      @default("not-started")
  lastEventType         String?
  lastEventPayload      Json?
  lastCode              String?
  lastWabaId            String?
  lastPhoneNumberId     String?
  lastBusinessAccountId String?
  linkedAccessToken     String?
  linkedTokenType       String?
  linkedAt              DateTime?
  departmentId          String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  department            Department? @relation(fields: [departmentId], references: [id])

  @@index([provider])
  @@index([onboardingStatus])
  @@index([departmentId])
}

model Department {
  id                  String                       @id @default(cuid())
  name                String
  description         String?
  businessHours       Json?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  userRoles           UserDepartmentRole[]
  botConfigs          BotConfig[]
  knowledgeBase       KnowledgeBase[]
  channelIntegrations ChannelIntegration[]
  leads               Lead[]
  conversations       MessageConversation[]
  roundRobinStates    RoundRobinState[]
  channelConfigs      MessageChannelConfigRecord[]
  appointments        Appointment[]
  scheduledFollowUps  ScheduledFollowUp[]
  professionals       Professional[]
  timeBlocks          TimeBlock[]
}

model UserDepartmentRole {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  role         UserRole   @default(SALES)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

model BotConfig {
  id           String     @id @default(cuid())
  departmentId String
  prompt       String
  model        String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
}

model KnowledgeBase {
  id           String     @id @default(cuid())
  departmentId String
  title        String
  content      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
}

model ChannelIntegration {
  id                String     @id @default(cuid())
  provider          String
  accessToken       String
  providerAccountId String
  departmentId      String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([provider])
  @@index([providerAccountId])
}

model Appointment {
  id             String            @id @default(cuid())
  externalId     String?
  leadId         String
  departmentId   String
  professionalId String?
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lead           Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  department     Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  professional   Professional?     @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([departmentId])
  @@index([professionalId])
  @@index([startTime])
}

model Professional {
  id            String        @id @default(cuid())
  name          String
  departmentId  String
  userId        String?
  businessHours Json?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  timeBlocks    TimeBlock[]

  @@index([departmentId])
}

model TimeBlock {
  id             String        @id @default(cuid())
  departmentId   String
  professionalId String?
  startTime      DateTime
  endTime        DateTime
  reason         String
  createdAt      DateTime      @default(now())
  department     Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([departmentId, startTime])
}

model ScheduledFollowUp {
  id           String         @id @default(cuid())
  leadId       String
  departmentId String
  scheduledFor DateTime
  status       FollowUpStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  department   Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([departmentId])
  @@index([status])
}

model ConversationInsight {
  conversationId String              @id
  sentiment      String
  objections     String[]            @default([])
  summary        String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
