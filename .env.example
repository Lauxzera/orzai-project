OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_MODEL_ASSISTANT=google/gemma-4-31b-it:free
OPENROUTER_MODEL_LEAD_ANALYSIS=openai/gpt-oss-20b:free
OPENROUTER_MODEL_CONVERSATION_ANALYSIS=openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Belart CRM

DATABASE_URL="postgresql://prisma.seu_project_ref:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://prisma.seu_project_ref:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
SUPABASE_DATABASE_URL="postgresql://prisma.seu_project_ref:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
SUPABASE_DIRECT_URL="postgresql://prisma.seu_project_ref:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
AUTH_SECRET=troque_por_uma_chave_longa_e_aleatoria
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Disparo de campanhas fora da janela de atendimento de 24h (opcional).
# Sem isso configurado, leads que nao responderam ha mais de 24h sao
# marcados como "pulados" em vez de falhar contra a Graph API.
# O template precisa existir e estar APROVADO no Meta Business Manager
# antes de ser usado aqui.
WHATSAPP_FALLBACK_TEMPLATE_NAME=
WHATSAPP_FALLBACK_TEMPLATE_LANGUAGE=pt_BR

# URL pública do CRM (sem barra final) — usada para montar webhook e callback URLs
APP_URL=https://crm-institutobelart.vercel.app

# ─────────────────────────────────────────────
# WhatsApp Cloud API — credenciais base
# ─────────────────────────────────────────────
WHATSAPP_PROVIDER=meta
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# ─────────────────────────────────────────────
# WhatsApp Embedded Signup / Coexistence
# Docs: docs/whatsapp-meta-setup.md
# ─────────────────────────────────────────────

# Habilitar fluxo de Embedded Signup e Coexistence
META_EMBEDDED_SIGNUP_ENABLED=false
META_COEXISTENCE_ENABLED=false

# App ID do seu app Meta Developers (mesmo valor que NEXT_PUBLIC_META_APP_ID)
META_EMBEDDED_SIGNUP_APP_ID=

# Configuration ID do Facebook Login for Business / WhatsApp Embedded Signup
META_EMBEDDED_SIGNUP_CONFIG_ID=2041214766787970

# Redirect URI registrada no Meta Developers como OAuth Redirect URI.
# Deve ser EXATAMENTE: https://crm-institutobelart.vercel.app/auth/meta/callback
# Deixe vazio para usar APP_URL + /auth/meta/callback automaticamente.
META_EMBEDDED_SIGNUP_REDIRECT_URI=

# Versão da Graph API usada no backend para troca de tokens
META_GRAPH_API_VERSION=v23.0

# ─────────────────────────────────────────────
# Variáveis públicas (expostas ao frontend via NEXT_PUBLIC_)
# ─────────────────────────────────────────────

# App ID do Meta Developers — mesmo valor que META_EMBEDDED_SIGNUP_APP_ID
NEXT_PUBLIC_META_APP_ID=

# Configuration ID do Embedded Signup — mesmo valor que META_EMBEDDED_SIGNUP_CONFIG_ID
NEXT_PUBLIC_META_CONFIG_ID=2041214766787970

# Versão da Graph API usada no frontend para inicializar o SDK
NEXT_PUBLIC_META_GRAPH_API_VERSION=v23.0

# ─────────────────────────────────────────────
# Segurança
# ─────────────────────────────────────────────

# Token de verificação do webhook WhatsApp (string aleatória segura)
WHATSAPP_VERIFY_TOKEN=

# Chave de criptografia AES-256 para o access token (mínimo 32 chars)
ENCRYPTION_SECRET=

# ─────────────────────────────────────────────
# Google Sheets (opcional)
# ─────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Leads!A:Z
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
